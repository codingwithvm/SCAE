{
  "name": "scae",
  "version": "0.1.0",
  "private": true,
  "description": "SCAE - Sistema de Apoio ao Ensino-Aprendizagem",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "npm run dev --workspace=apps/web",
    "services:up": "docker compose --env-file apps/web/.env.development -f apps/web/infra/docker-compose.development.yml up -d",
    "services:stop": "docker compose --env-file apps/web/.env.development -f apps/web/infra/docker-compose.development.yml stop",
    "services:down": "docker compose --env-file apps/web/.env.development -f apps/web/infra/docker-compose.development.yml down",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "eslint .",
    "test:web": "npm run test --workspace=apps/web",
    "test:web:watch": "npm run test:watch --workspace=apps/web",
    "typecheck:web": "npm run typecheck --workspace=apps/web"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "pg": "^8.20.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.58.2"
  }
}
