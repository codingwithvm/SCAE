generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TEACHER
  SCHOOL_MANAGER
  MUNICIPAL_MANAGER
  ADMIN
}

model User {
  id                 String    @id @default(uuid())
  role               Role
  name               String
  email              String?   @unique
  registrationNumber String?   @unique
  birthDate          DateTime?
  passwordHash       String?
  schoolId              String?
  municipalityId        String?
  scaeProfile           String?
  onboardingCompleted   Boolean   @default(false)
  mceUnlocked           Boolean   @default(false)
  onboardingCompletedAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  school          School?        @relation(fields: [schoolId], references: [id])
  municipality    Municipality?  @relation(fields: [municipalityId], references: [id])
  taughtClasses   TeacherClass[]
  enrolledClasses StudentClass[]

  releases        AssessmentRelease[] @relation("UserReleases")
  releasesGranted AssessmentRelease[] @relation("ReleasedByUser")
  assessments     Assessment[]
  reportsSent     ReportDelivery[]    @relation("SentByUser")
  notifications   Notification[]
  studentBadges   StudentBadge[]
  activitySessions ActivitySession[]
  studentProgress  StudentProgress[]
  activitiesCreated Activity[]      @relation("ActivitiesCreated")

  @@index([email])
  @@index([registrationNumber])
  @@index([role])
  @@index([schoolId])
  @@index([municipalityId])
  @@map("scae_users")
}

model Municipality {
  id        String    @id @default(uuid())
  name      String
  state     String    @db.Char(2)
  ibgeCode  String    @unique @map("ibge_code")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  schools School[]
  users   User[]

  @@index([state])
  @@index([ibgeCode])
  @@map("scae_municipalities")
}

model School {
  id             String    @id @default(uuid())
  municipalityId String
  name           String
  inepCode       String    @unique @map("inep_code")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  municipality Municipality @relation(fields: [municipalityId], references: [id])
  classes      Class[]
  users        User[]

  @@index([municipalityId])
  @@index([inepCode])
  @@map("scae_schools")
}

model Class {
  id        String    @id @default(uuid())
  schoolId  String
  name      String
  grade     Int
  year      Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  school             School              @relation(fields: [schoolId], references: [id])
  teacherAssignments TeacherClass[]
  studentEnrollments StudentClass[]
  assessmentReleases AssessmentRelease[]

  @@index([schoolId])
  @@index([year])
  @@map("scae_classes")
}

model TeacherClass {
  teacherId String
  classId   String

  teacher User  @relation(fields: [teacherId], references: [id])
  class   Class @relation(fields: [classId], references: [id])

  @@id([teacherId, classId])
  @@index([classId])
  @@map("scae_teacher_classes")
}

model StudentClass {
  studentId  String
  classId    String
  enrolledAt DateTime @default(now())

  student User  @relation(fields: [studentId], references: [id])
  class   Class @relation(fields: [classId], references: [id])

  @@id([studentId, classId])
  @@index([classId])
  @@map("scae_student_classes")
}

enum Instrument {
  MCEES_1A4
  MCEES_5A9
  MCEES_PROF
  MEES_PROF
}

enum ReleaseState {
  PENDING
  IN_USE
  CONSUMED
  EXPIRED
}

enum AssessmentState {
  STARTED
  IN_PROGRESS
  COMPLETE
  ABANDONED
}

enum ConsistencyTier {
  CONFIRMED
  PREDOMINANT
  IN_MAPPING
}

model AssessmentRelease {
  id           String       @id @default(uuid())
  userId       String
  instrument   Instrument
  releasedById String       @map("released_by_id")
  classId      String?
  state        ReleaseState @default(PENDING)
  expiresAt    DateTime?    @map("expires_at")
  consumedAt   DateTime?    @map("consumed_at")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user       User        @relation("UserReleases", fields: [userId], references: [id])
  releasedBy User        @relation("ReleasedByUser", fields: [releasedById], references: [id])
  class      Class?      @relation(fields: [classId], references: [id])
  assessment Assessment?

  @@index([userId])
  @@index([classId])
  @@index([state])
  @@map("scae_assessment_releases")
}

model Assessment {
  id               String          @id @default(uuid())
  userId           String
  instrument       Instrument
  releaseId        String?         @unique @map("release_id")
  state            AssessmentState @default(STARTED)
  responsesJson    Json?           @map("responses_json")
  startedAt        DateTime        @default(now()) @map("started_at")
  completedAt      DateTime?       @map("completed_at")
  totalTimeSeconds Int?            @map("total_time_seconds")
  ipAddress        String?         @map("ip_address") @db.VarChar(45)
  userAgent        String?         @map("user_agent")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user    User               @relation(fields: [userId], references: [id])
  release AssessmentRelease? @relation(fields: [releaseId], references: [id])
  result  AssessmentResult?

  @@index([userId])
  @@index([instrument])
  @@index([state])
  @@map("scae_assessments")
}

model AssessmentResult {
  id             String          @id @default(uuid())
  assessmentId   String          @unique @map("assessment_id")
  profile        String
  quadrant       Int?
  axisX          Decimal         @map("axis_x") @db.Decimal(8, 4)
  axisY          Decimal         @map("axis_y") @db.Decimal(8, 4)
  confX          Decimal?        @map("conf_x") @db.Decimal(5, 2)
  confY          Decimal?        @map("conf_y") @db.Decimal(5, 2)
  tier           ConsistencyTier
  scoresJson     Json            @map("scores_json")
  fullResultJson Json            @map("full_result_json")
  engineVersion  String          @default("1.0.0") @map("engine_version") @db.VarChar(20)
  createdAt      DateTime        @default(now())

  assessment       Assessment       @relation(fields: [assessmentId], references: [id])
  reportDeliveries ReportDelivery[]

  @@map("scae_assessment_results")
}

model ReportDelivery {
  id             String    @id @default(uuid())
  resultId       String    @map("result_id")
  sentById       String    @map("sent_by_id")
  recipientEmail String    @map("recipient_email") @db.VarChar(255)
  tokenHash      String    @unique @map("token_hash") @db.VarChar(64)
  tokenExpiresAt DateTime  @map("token_expires_at")
  deliveryState  String    @default("sent") @map("delivery_state") @db.VarChar(20)
  openedAt       DateTime? @map("opened_at")
  createdAt      DateTime  @default(now())

  result AssessmentResult @relation(fields: [resultId], references: [id])
  sentBy User             @relation("SentByUser", fields: [sentById], references: [id])

  @@index([resultId])
  @@index([tokenHash])
  @@map("scae_report_deliveries")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(200)
  message   String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("scae_notifications")
}

model Badge {
  id          String @id
  name        String @db.VarChar(100)
  description String
  category    String @db.VarChar(20)
  icon        String @db.VarChar(50)
  color       String @db.VarChar(100)
  criteria    Json?

  studentBadges StudentBadge[]

  @@map("scae_badges")
}

model StudentBadge {
  id       String   @id @default(uuid())
  userId   String
  badgeId  String
  context  String?
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId, context])
  @@index([userId])
  @@map("scae_student_badges")
}

model Activity {
  id              String   @id @default(uuid())
  habilidadeCode  String   @db.VarChar(20)
  habilidadeDesc  String
  discipline      String   @db.VarChar(5)
  grade           String   @db.VarChar(5)
  title           String   @db.VarChar(200)
  htmlContent     String
  activityVersion String   @default("v4") @db.VarChar(10)
  isActive        Boolean  @default(true)
  level1Content   String
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy User?             @relation("ActivitiesCreated", fields: [createdById], references: [id])
  sessions  ActivitySession[]
  progress  StudentProgress[]

  @@index([habilidadeCode])
  @@index([discipline])
  @@index([grade])
  @@index([isActive])
  @@map("scae_activities")
}

model ActivitySession {
  id              String    @id @default(uuid())
  userId          String
  activityId      String
  status          String    @default("started") @db.VarChar(20)
  scaeLevel       String?   @db.VarChar(20)
  spaeceLevel     String?   @db.VarChar(30)
  level1Score     Float?
  level2Score     Float?
  level3Score     Float?
  totalScore      Float?
  confidenceIndex Float?
  timeSpentSecs   Int?
  reflectionData  String?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user      User               @relation(fields: [userId], references: [id])
  activity  Activity           @relation(fields: [activityId], references: [id])
  responses ActivityResponse[]

  @@index([userId])
  @@index([activityId])
  @@index([status])
  @@map("scae_activity_sessions")
}

model ActivityResponse {
  id               String   @id @default(uuid())
  sessionId        String
  questionId       String   @db.VarChar(50)
  questionText     String
  level            Int
  selectedOption   String   @db.VarChar(5)
  correctOption    String   @db.VarChar(5)
  isCorrect        Boolean
  points           Int
  spaeceDescriptor String?  @db.VarChar(20)
  responseTimeMs   Int?
  createdAt        DateTime @default(now())

  session ActivitySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("scae_activity_responses")
}

model StudentProgress {
  id               String   @id @default(uuid())
  userId           String
  activityId       String
  habilidadeCode   String   @db.VarChar(20)
  discipline       String   @db.VarChar(5)
  grade            Int
  attemptsCount    Int      @default(0)
  completionsCount Int      @default(0)
  bestScaeLevel    String?  @db.VarChar(20)
  currentScaeLevel String?  @db.VarChar(20)
  bestScore        Float?
  averageScore     Float?
  needsAttention   Boolean  @default(false)
  evolutionData    String?
  firstAttemptAt   DateTime @default(now())
  lastAttemptAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id])
  activity Activity @relation(fields: [activityId], references: [id])

  @@unique([userId, habilidadeCode])
  @@index([userId])
  @@index([habilidadeCode])
  @@index([needsAttention])
  @@map("scae_student_progress")
}
