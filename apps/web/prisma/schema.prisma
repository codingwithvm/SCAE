generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TEACHER
  SCHOOL_MANAGER
  MUNICIPAL_MANAGER
  ADMIN
}

model User {
  id                 String    @id @default(uuid())
  role               Role
  name               String
  email              String?   @unique
  registrationNumber String?   @unique
  birthDate          DateTime?
  passwordHash       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  @@index([email])
  @@index([registrationNumber])
  @@index([role])
  @@map("scae_users")
}

model Municipality {
  id        String    @id @default(uuid())
  name      String
  state     String    @db.Char(2)
  ibgeCode  String    @unique @map("ibge_code")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  schools School[]

  @@index([state])
  @@index([ibgeCode])
  @@map("scae_municipalities")
}

model School {
  id             String       @id @default(uuid())
  municipalityId String
  name           String
  inepCode       String       @unique @map("inep_code")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  municipality Municipality @relation(fields: [municipalityId], references: [id])
  classes      Class[]

  @@index([municipalityId])
  @@index([inepCode])
  @@map("scae_schools")
}

model Class {
  id        String    @id @default(uuid())
  schoolId  String
  name      String
  grade     Int
  year      Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([year])
  @@map("scae_classes")
}
