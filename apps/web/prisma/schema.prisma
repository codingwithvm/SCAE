generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TEACHER
  SCHOOL_MANAGER
  MUNICIPAL_MANAGER
  ADMIN
}

model User {
  id                 String    @id @default(uuid())
  role               Role
  name               String
  email              String?   @unique
  registrationNumber String?   @unique
  birthDate          DateTime?
  passwordHash       String?
  schoolId           String?
  municipalityId     String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  school          School?       @relation(fields: [schoolId], references: [id])
  municipality    Municipality? @relation(fields: [municipalityId], references: [id])
  taughtClasses   TeacherClass[]
  enrolledClasses StudentClass[]

  @@index([email])
  @@index([registrationNumber])
  @@index([role])
  @@index([schoolId])
  @@index([municipalityId])
  @@map("scae_users")
}

model Municipality {
  id        String    @id @default(uuid())
  name      String
  state     String    @db.Char(2)
  ibgeCode  String    @unique @map("ibge_code")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  schools School[]
  users   User[]

  @@index([state])
  @@index([ibgeCode])
  @@map("scae_municipalities")
}

model School {
  id             String       @id @default(uuid())
  municipalityId String
  name           String
  inepCode       String       @unique @map("inep_code")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  municipality Municipality @relation(fields: [municipalityId], references: [id])
  classes      Class[]
  users        User[]

  @@index([municipalityId])
  @@index([inepCode])
  @@map("scae_schools")
}

model Class {
  id        String    @id @default(uuid())
  schoolId  String
  name      String
  grade     Int
  year      Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  school            School         @relation(fields: [schoolId], references: [id])
  teacherAssignments TeacherClass[]
  studentEnrollments StudentClass[]

  @@index([schoolId])
  @@index([year])
  @@map("scae_classes")
}

model TeacherClass {
  teacherId String
  classId   String

  teacher User  @relation(fields: [teacherId], references: [id])
  class   Class @relation(fields: [classId], references: [id])

  @@id([teacherId, classId])
  @@index([classId])
  @@map("scae_teacher_classes")
}

model StudentClass {
  studentId  String
  classId    String
  enrolledAt DateTime @default(now())

  student User  @relation(fields: [studentId], references: [id])
  class   Class @relation(fields: [classId], references: [id])

  @@id([studentId, classId])
  @@index([classId])
  @@map("scae_student_classes")
}
