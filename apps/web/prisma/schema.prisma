generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TEACHER
  SCHOOL_MANAGER
  MUNICIPAL_MANAGER
  ADMIN
}

model User {
  id                 String    @id @default(uuid())
  role               Role
  name               String
  email              String?   @unique
  registrationNumber String?   @unique
  birthDate          DateTime?
  passwordHash       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  @@index([email])
  @@index([registrationNumber])
  @@index([role])
  @@map("scae_users")
}

model Municipality {
  id        String    @id @default(uuid())
  name      String
  state     String    @db.Char(2)
  ibgeCode  String    @unique @map("ibge_code")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([state])
  @@index([ibgeCode])
  @@map("scae_municipalities")
}
